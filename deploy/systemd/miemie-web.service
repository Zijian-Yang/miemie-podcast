[Unit]
Description=Miemie Podcast Web
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/miemie-podcast/apps/web
EnvironmentFile=/opt/miemie-podcast/.env
Environment=APP_ENV=production
ExecStart=/usr/bin/npm run start -- --hostname ${APP_HOST} --port ${APP_PORT}
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
